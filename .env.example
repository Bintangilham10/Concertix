# ══════════════════════════════════════════════════════════════
# Concertix Environment Variables
# ══════════════════════════════════════════════════════════════

# Database (PostgreSQL)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=concertix
POSTGRES_USER=concertix_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://concertix_user:your_secure_password_here@db:5432/concertix

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key

# ── DevSecOps Additions ──────────────────────────────────────

# T7: CORS production whitelist
CORS_ALLOWED_ORIGIN=https://your-production-domain.com

# Redis
REDIS_URL=redis://redis:6379/0

# Grafana
GRAFANA_PASSWORD=concertix_grafana
