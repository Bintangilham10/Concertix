# ══════════════════════════════════════════════════════════════
# Concertix Environment Variables
# ══════════════════════════════════════════════════════════════

# Database (PostgreSQL)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=concertix
POSTGRES_USER=concertix_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend (FastAPI)
BACKEND_PORT=8000
DATABASE_URL=postgresql://concertix_user:your_secure_password_here@db:5432/concertix
DEBUG=true
EXPOSE_API_DOCS=true
EXPOSE_METRICS=true

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key

# ── DevSecOps Additions ──────────────────────────────────────

# T7: CORS production whitelist
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Redis
REDIS_URL=redis://redis:6379/0
TOKEN_BLACKLIST_FAIL_CLOSED=false

# Rate limiting
# Leave empty to reuse REDIS_URL. Set TRUST_PROXY_HEADERS=true only behind
# a trusted platform proxy such as Railway/Vercel, never for a raw public host.
RATE_LIMIT_STORAGE_URL=
TRUST_PROXY_HEADERS=false

# Password reset OTP email
# In DEBUG=true without SMTP_HOST, backend logs the OTP for local demo.
# In production, configure SMTP so OTP can be emailed to registered users.
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Grafana
GRAFANA_PASSWORD=your_secure_grafana_password_here
